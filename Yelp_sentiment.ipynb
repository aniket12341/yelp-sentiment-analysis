      "source": [
        "# Function to plot confusion matrix (3-class)\n",
        "from sklearn.preprocessing import label_binarize\n",
        "from sklearn.metrics import roc_curve, auc\n",
        "\n",
        "CLASS_NAMES = ['Negative', 'Neutral', 'Positive']\n",
        "\n",
        "def plot_confusion_matrix(y_true, y_pred, model_name, figsize=(8, 6)):\n",
        "    cm = confusion_matrix(y_true, y_pred)\n",
        "    plt.figure(figsize=figsize)\n",
        "    sns.heatmap(cm, annot=True, fmt='d', cmap='Blues',\n",
        "                xticklabels=CLASS_NAMES,\n",
        "                yticklabels=CLASS_NAMES,\n",
        "                cbar_kws={'label': 'Count'})\n",
        "    plt.title(f'Confusion Matrix - {model_name}', fontsize=14, fontweight='bold')\n",
        "    plt.ylabel('True Label', fontsize=12)\n",
        "    plt.xlabel('Predicted Label', fontsize=12)\n",
        "    plt.tight_layout()\n",
        "    plt.show()\n",
        "    return cm\n",
        "\n",
        "# Function to plot ROC curves (One-vs-Rest for 3-class)\n",
        "def plot_roc_curves(y_true, y_scores, model_name, n_classes=3):\n",
        "    \"\"\"Plot per-class ROC curves using One-vs-Rest.\n",
        "    y_scores: (n_samples, n_classes) probabilities or decision function scores.\n",
        "    \"\"\"\n",
        "    y_true_bin = label_binarize(y_true, classes=list(range(n_classes)))\n",
        "\n",
        "    # If 1-D scores (e.g. binary decision function), reshape\n",
        "    if hasattr(y_scores, 'shape') and len(y_scores.shape) == 1:\n",
        "        y_scores = np.column_stack([y_scores] * n_classes)\n",
        "\n",
        "    fig, axes = plt.subplots(1, n_classes, figsize=(6 * n_classes, 5))\n",
        "    fig.suptitle(f'ROC Curves (One-vs-Rest) - {model_name}', fontsize=16, fontweight='bold')\n",
        "\n",
        "    colors = ['#e74c3c', '#f39c12', '#2ecc71']\n",
        "    aucs = []\n",
        "\n",
        "    for idx in range(n_classes):\n",
        "        fpr, tpr, _ = roc_curve(y_true_bin[:, idx], y_scores[:, idx])\n",
        "        roc_auc = auc(fpr, tpr)\n",
        "        aucs.append(roc_auc)\n",
        "\n",
        "        axes[idx].plot(fpr, tpr, color=colors[idx], lw=2,\n",
        "                       label=f'ROC (AUC = {roc_auc:.4f})')\n",
        "        axes[idx].plot([0, 1], [0, 1], 'k--', lw=1, label='Random')\n",
        "        axes[idx].set_xlim([0.0, 1.0])\n",
        "        axes[idx].set_ylim([0.0, 1.05])\n",
        "        axes[idx].set_xlabel('False Positive Rate', fontsize=10)\n",
        "        axes[idx].set_ylabel('True Positive Rate', fontsize=10)\n",
        "        axes[idx].set_title(f'{CLASS_NAMES[idx]} (One-vs-Rest)', fontsize=12)\n",
        "        axes[idx].legend(loc='lower right', fontsize=9)\n",
        "        axes[idx].grid(alpha=0.3)\n",
        "\n",
        "    plt.tight_layout()\n",
        "    plt.show()\n",
        "    return aucs"
      ]
    },
