      "source": [
        "# Prepare dataset for transformer fine-tuning (3-class)\n",
        "TRANSFORMER_TRAIN = min(50000, len(dataset['train']))\n",
        "TRANSFORMER_TEST = min(10000, len(dataset['test']))\n",
        "\n",
        "train_dataset_hf = dataset['train'].shuffle(seed=42).select(range(TRANSFORMER_TRAIN))\n",
        "test_dataset_hf = dataset['test'].shuffle(seed=42).select(range(TRANSFORMER_TEST))\n",
        "\n",
        "def tokenize_function(examples, tokenizer):\n",
        "    return tokenizer(examples['text'], padding='max_length', truncation=True, max_length=256)\n",
        "\n",
        "print(f\"Prepared datasets for transformer fine-tuning (3-class sentiment)\")\n",
        "print(f\"Train: {len(train_dataset_hf)} samples\")\n",
        "print(f\"Test: {len(test_dataset_hf)} samples\")\n",
        "print(f\"Labels: 0=Negative, 1=Neutral, 2=Positive\")"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "id": "5_2whLkijjKK",
      "metadata": {
        "id": "5_2whLkijjKK"
      },
      "outputs": [],
      "source": [
        "# Custom Trainer to capture training/validation loss\n",
        "class CustomTrainer(Trainer):\n",
        "    def __init__(self, *args, **kwargs):\n",
        "        super().__init__(*args, **kwargs)\n",
        "        self.train_losses = []\n",
        "        self.eval_losses = []\n",
        "\n",
        "    def log(self, logs, *args, **kwargs):\n",
        "        super().log(logs, *args, **kwargs)\n",
        "        if 'loss' in logs:\n",
        "            self.train_losses.append(logs['loss'])\n",
        "        if 'eval_loss' in logs:\n",
        "            self.eval_losses.append(logs['eval_loss'])\n",
        "\n",
        "# Compute metrics function\n",
        "def compute_metrics(eval_pred):\n",
        "    logits, labels = eval_pred\n",
        "    predictions = np.argmax(logits, axis=-1)\n",
        "\n",
        "    accuracy = accuracy_score(labels, predictions)\n",
        "    precision = precision_score(labels, predictions, average='weighted', zero_division=0)\n",
        "    recall = recall_score(labels, predictions, average='weighted', zero_division=0)\n",
        "    f1 = f1_score(labels, predictions, average='weighted', zero_division=0)\n",
        "\n",
        "    return {\n",
        "        'accuracy': accuracy,\n",
        "        'precision': precision,\n",
        "        'recall': recall,\n",
        "        'f1': f1\n",
        "    }"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "id": "FbEh7g-ejk2L",
      "metadata": {
        "id": "FbEh7g-ejk2L"
      },
      "outputs": [],
      "source": [
        "# Function to train and evaluate transformer models (3-class sentiment)\n",
        "def train_and_evaluate_transformer(model_name, train_data, test_data, num_epochs=3):\n",
        "    print(f\"Training {model_name}\")\n",
        "\n",
        "    # Load tokenizer and model\n",
        "    print(f\"Loading tokenizer and model...\")\n",
        "    tokenizer = AutoTokenizer.from_pretrained(model_name)\n",
        "    model = AutoModelForSequenceClassification.from_pretrained(model_name, num_labels=3)\n",
        "    model.to(device)\n",
        "\n",
        "    # Tokenize datasets\n",
        "    print(\"Tokenizing datasets...\")\n",
        "    tokenize_start = time.time()\n",
        "    train_tokenized = train_data.map(\n",
        "        lambda x: tokenize_function(x, tokenizer),\n",
        "        batched=True\n",
        "    )\n",
        "    test_tokenized = test_data.map(\n",
        "        lambda x: tokenize_function(x, tokenizer),\n",
        "        batched=True\n",
        "    )\n",
        "    tokenize_time = time.time() - tokenize_start\n",
        "    print(f\"Tokenization completed in {tokenize_time:.2f} seconds\")\n",
        "\n",
        "    # Define training arguments\n",
        "    training_args = TrainingArguments(\n",
        "        output_dir=f'./results_{model_name.replace(\"/\", \"_\")}',\n",
        "        num_train_epochs=num_epochs,\n",
        "        per_device_train_batch_size=16,\n",
        "        per_device_eval_batch_size=32,\n",
        "        warmup_steps=500,\n",
        "        weight_decay=0.01,\n",
        "        logging_steps=100,\n",
        "        eval_strategy=\"epoch\",\n",
        "        save_strategy=\"epoch\",\n",
        "        learning_rate=2e-5,\n",
        "        load_best_model_at_end=True,\n",
        "        metric_for_best_model=\"accuracy\",\n",
        "        report_to=[],\n",
        "        fp16=torch.cuda.is_available()\n",
        "        disable_tqdm=True\n",
        "    )\n",
        "\n",
        "    # Create trainer\n",
        "    trainer = CustomTrainer(\n",
        "        model=model,\n",
        "        args=training_args,\n",
        "        train_dataset=train_tokenized,\n",
        "        eval_dataset=test_tokenized,\n",
        "        compute_metrics=compute_metrics,\n",
        "    )\n",
        "\n",
        "    # Track memory usage\n",
        "    process = psutil.Process(os.getpid())\n",
        "    mem_before = process.memory_info().rss / 1024 ** 3  # GB\n",
        "    if torch.cuda.is_available():\n",
        "        torch.cuda.reset_peak_memory_stats()\n",
        "        torch.cuda.empty_cache()\n",
        "\n",
        "    # Train the model\n",
        "    print(f\"\\nStarting fine-tuning for {num_epochs} epochs...\")\n",
        "    train_start = time.time()\n",
        "    train_result = trainer.train()\n",
        "    train_time = time.time() - train_start\n",
        "\n",
        "    mem_after = process.memory_info().rss / 1024 ** 3  # GB\n",
        "    mem_used = mem_after - mem_before\n",
        "\n",
        "    gpu_mem_used = 0\n",
        "    if torch.cuda.is_available():\n",
        "        gpu_mem_used = torch.cuda.max_memory_allocated() / 1024 ** 3  # GB\n",
        "\n",
        "    print(f\"\\nFine-tuning completed in {train_time:.2f} seconds ({train_time/60:.2f} minutes)\")\n",
        "    print(f\"Final training loss: {train_result.training_loss:.4f}\")\n",
        "    print(f\"CPU Memory used: {mem_used:.2f} GB\")\n",
        "    if torch.cuda.is_available():\n",
        "        print(f\"GPU Memory used: {gpu_mem_used:.2f} GB\")\n",
        "\n",
        "    # Evaluate on test set\n",
        "    print(f\"\\nEvaluating on test set...\")\n",
        "    eval_start = time.time()\n",
        "    eval_results = trainer.evaluate()\n",
        "    eval_time = time.time() - eval_start\n",
        "\n",
        "    # Inference speed test\n",
        "    print(f\"\\nTesting inference speed...\")\n",
        "    inference_start = time.time()\n",
        "    predictions = trainer.predict(test_tokenized)\n",
        "    inference_time = time.time() - inference_start\n",
        "    inference_per_sample = (inference_time / len(test_data)) * 1000  # ms\n",
        "\n",
        "    # Get predictions for classification report\n",
        "    pred_labels = np.argmax(predictions.predictions, axis=-1)\n",
        "    true_labels = [ex['label'] for ex in test_data]\n",
        "\n",
        "    # Convert logits to probabilities using softmax for ROC curves\n",
        "    import torch.nn.functional as F\n",
        "    pred_logits = torch.tensor(predictions.predictions)\n",
        "    pred_probabilities = F.softmax(pred_logits, dim=-1).numpy()\n",
        "\n",
        "    print(f\"\\n=== {model_name} Results ===\")\n",
        "    print(f\"Accuracy: {eval_results['eval_accuracy']:.4f}\")\n",
        "    print(f\"Precision: {eval_results['eval_precision']:.4f}\")\n",
        "    print(f\"Recall: {eval_results['eval_recall']:.4f}\")\n",
        "    print(f\"F1-Score: {eval_results['eval_f1']:.4f}\")\n",
        "    print(f\"Training time: {train_time:.2f}s ({train_time/60:.2f} min)\")\n",
        "    print(f\"Inference time: {inference_time:.2f}s ({inference_per_sample:.2f}ms per sample)\")\n",
        "    print(f\"\\nClassification Report:\")\n",
        "    print(classification_report(true_labels, pred_labels, target_names=['Negative', 'Neutral', 'Positive']))\n",
        "\n",
        "    # Return results dictionary\n",
        "    return {\n",
        "        'model_name': model_name,\n",
        "        'accuracy': eval_results['eval_accuracy'],\n",
        "        'precision': eval_results['eval_precision'],\n",
        "        'recall': eval_results['eval_recall'],\n",
        "        'f1': eval_results['eval_f1'],\n",
        "        'train_time': train_time,\n",
        "        'inference_time': inference_time,\n",
        "        'inference_per_sample': inference_per_sample,\n",
        "        'cpu_mem_used': mem_used,\n",
        "        'gpu_mem_used': gpu_mem_used,\n",
        "        'train_losses': trainer.train_losses,\n",
        "        'probabilities': pred_probabilities,\n",
        "        'eval_losses': trainer.eval_losses,\n",
        "        'predictions': pred_labels,\n",
        "        'true_labels': true_labels\n",
        "    }"
      ]
    },
