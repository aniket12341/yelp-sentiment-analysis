      "source": [
        "# Load Yelp review dataset (full 5-class version)\n",
        "print(\"Loading Yelp review dataset...\")\n",
        "dataset = load_dataset(\"yelp_review_full\")\n",
        "\n",
        "print(\"\\nOriginal dataset structure:\")\n",
        "print(dataset)\n",
        "print(f\"\\nTrain samples: {len(dataset['train'])}\")\n",
        "print(f\"Test samples: {len(dataset['test'])}\")\n",
        "\n",
        "# Convert to 3-CLASS sentiment: Negative / Neutral / Positive\n",
        "# Original labels: 0=1★, 1=2★, 2=3★, 3=4★, 4=5★\n",
        "# Mapping: 0,1 → Negative (0) | 2 → Neutral (1) | 3,4 → Positive (2)\n",
        "print(\"\\nConverting to 3-class sentiment (Negative / Neutral / Positive)...\")\n",
        "\n",
        "def map_to_3class(example):\n",
        "    if example['label'] <= 1:\n",
        "        return {'label': 0}   # Negative\n",
        "    elif example['label'] == 2:\n",
        "        return {'label': 1}   # Neutral\n",
        "    else:\n",
        "        return {'label': 2}   # Positive\n",
        "\n",
        "dataset = dataset.map(map_to_3class)\n",
        "\n",
        "print(f\"\\n3-class dataset:\")\n",
        "print(f\"Train samples: {len(dataset['train'])}\")\n",
        "print(f\"Test samples: {len(dataset['test'])}\")\n",
        "\n",
        "# Verify label distribution\n",
        "train_labels = [ex['label'] for ex in dataset['train']]\n",
        "print(f\"Negative (0): {train_labels.count(0):,}\")\n",
        "print(f\"Neutral  (1): {train_labels.count(1):,}\")\n",
        "print(f\"Positive (2): {train_labels.count(2):,}\")"
      ]
    },
