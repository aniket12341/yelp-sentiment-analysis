        "import nltk\n",
        "from nltk.corpus import stopwords\n",
        "from nltk.stem import WordNetLemmatizer\n",
        "from nltk.tokenize import word_tokenize\n",
        "import string\n",
        "\n",
        "# Download necessary NLTK data\n",
        "try:\n",
        "    stopwords.words('english')\n",
        "except LookupError:\n",
        "    nltk.download('stopwords')\n",
        "\n",
        "try:\n",
        "    WordNetLemmatizer().lemmatize('test')\n",
        "except LookupError:\n",
        "    nltk.download('wordnet')\n",
        "\n",
        "try:\n",
        "    word_tokenize('test')\n",
        "except LookupError:\n",
        "    nltk.download('punkt_tab')\n",
        "\n",
        "# Initialize NLTK components\n",
        "stop_words = set(stopwords.words('english'))\n",
        "lemmatizer = WordNetLemmatizer()\n",
        "\n",
        "def preprocess_text(text):\n",
        "    # 1. Lowercasing\n",
        "    text = text.lower()\n",
        "\n",
        "    # 2. Tokenization\n",
        "    tokens = word_tokenize(text)\n",
        "\n",
        "    # 3. Remove punctuation and non-alphabetic tokens\n",
        "    tokens = [word for word in tokens if word.isalpha()]\n",
        "\n",
        "    # 4. Remove stopwords\n",
        "    tokens = [word for word in tokens if word not in stop_words]\n",
        "\n",
        "    # 5. Lemmatization\n",
        "    tokens = [lemmatizer.lemmatize(word) for word in tokens]\n",
        "\n",
        "    return ' '.join(tokens)\n",
        "\n",
        "# Sample the 3-class dataset for ML models\n",
        "SAMPLE_SIZE_TRAIN = 80000\n",
        "SAMPLE_SIZE_TEST = 20000\n",
        "\n",
        "# Cap sample sizes to available data\n",
        "SAMPLE_SIZE_TRAIN = min(SAMPLE_SIZE_TRAIN, len(dataset['train']))\n",
        "SAMPLE_SIZE_TEST = min(SAMPLE_SIZE_TEST, len(dataset['test']))\n",
        "\n",
        "print(f\"Sampling {SAMPLE_SIZE_TRAIN:,} training and {SAMPLE_SIZE_TEST:,} test samples...\")\n",
        "\n",
        "train_dataset_sampled = dataset['train'].shuffle(seed=42).select(range(SAMPLE_SIZE_TRAIN))\n",
        "test_dataset_sampled = dataset['test'].shuffle(seed=42).select(range(SAMPLE_SIZE_TEST))\n",
        "\n",
        "# Extract texts and labels\n",
        "X_train = [example['text'] for example in train_dataset_sampled]\n",
        "y_train = [example['label'] for example in train_dataset_sampled]\n",
        "\n",
        "X_test = [example['text'] for example in test_dataset_sampled]\n",
        "y_test = [example['label'] for example in test_dataset_sampled]\n",
        "\n",
        "print(f\"Training samples: {len(X_train):,}\")\n",
        "print(f\"Test samples: {len(X_test):,}\")\n",
        "print(f\"Number of classes: {len(set(y_train))}\")\n",
        "print(f\"Label distribution (train): Neg={y_train.count(0):,}, Neu={y_train.count(1):,}, Pos={y_train.count(2):,}\")\n",
        "\n",
        "# Show preprocessing example\n",
        "sample_review = X_train[0]\n",
        "print(f\"\\nOriginal Review:\\n{sample_review[:200]}...\")\n",
        "\n",
        "# Apply preprocessing and show steps\n",
        "print(\"\\n--- Preprocessing Steps ---\")\n",
        "\n",
        "text_lower_tokens = word_tokenize(sample_review.lower())\n",
        "print(f\"1. Lowercased and Tokenized:\\n{' '.join(text_lower_tokens[:50])}...\")\n",
        "\n",
        "text_no_punct = [word for word in text_lower_tokens if word.isalpha()]\n",
        "print(f\"2. Removed Punctuation:\\n{' '.join(text_no_punct[:50])}...\")\n",
        "\n",
        "text_no_stopwords = [word for word in text_no_punct if word not in stop_words]\n",
        "print(f\"3. Removed Stopwords:\\n{' '.join(text_no_stopwords[:50])}...\")\n",
        "\n",
        "text_lemmatized = [lemmatizer.lemmatize(word) for word in text_no_stopwords]\n",
        "print(f\"4. Lemmatized:\\n{' '.join(text_lemmatized[:50])}...\")\n",
        "\n",
        "preprocessed_sample = preprocess_text(sample_review)\n",
        "print(f\"\\nFull Preprocessed Review:\\n{preprocessed_sample[:200]}...\")"
      ]
