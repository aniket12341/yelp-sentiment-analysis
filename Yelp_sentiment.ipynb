        "svm_tuned_preds = svm_best.predict(X_test_tfidf)\n",
        "svm_tuned_scores = svm_best.decision_function(X_test_tfidf)\n",
        "\n",
        "svm_tuned_accuracy = accuracy_score(y_test, svm_tuned_preds)\n",
        "svm_tuned_precision = precision_score(y_test, svm_tuned_preds, average='weighted', zero_division=0)\n",
        "svm_tuned_recall = recall_score(y_test, svm_tuned_preds, average='weighted', zero_division=0)\n",
        "svm_tuned_f1 = f1_score(y_test, svm_tuned_preds, average='weighted', zero_division=0)\n",
        "\n",
        "print(\"\\nTuned Linear SVM\")\n",
        "print(f\"Accuracy: {svm_tuned_accuracy:.4f}\")\n",
        "print(f\"Precision: {svm_tuned_precision:.4f}\")\n",
        "print(f\"Recall: {svm_tuned_recall:.4f}\")\n",
        "print(f\"F1-Score: {svm_tuned_f1:.4f}\")\n",
        "print(\"\\nClassification Report:\")\n",
        "print(classification_report(y_test, svm_tuned_preds, target_names=['Negative', 'Neutral', 'Positive']))\n",
        "\n",
        "# Visualizations\n",
        "print(\"\\nVisualizing tuned Logistic Regression...\")\n",
        "plot_confusion_matrix(y_test, lr_tuned_preds, 'Tuned Logistic Regression')\n",
        "lr_tuned_aucs = plot_roc_curves(y_test, lr_tuned_proba, 'Tuned Logistic Regression')\n",
        "for name, a in zip(CLASS_NAMES, lr_tuned_aucs):\n",
        "    print(f\"  Tuned LR {name} AUC: {a:.4f}\")\n",
        "\n",
        "print(\"\\nVisualizing tuned Linear SVM...\")\n",
        "plot_confusion_matrix(y_test, svm_tuned_preds, 'Tuned Linear SVM')\n",
        "svm_tuned_aucs = plot_roc_curves(y_test, svm_tuned_scores, 'Tuned Linear SVM')\n",
        "for name, a in zip(CLASS_NAMES, svm_tuned_aucs):\n",
        "    print(f\"  Tuned SVM {name} AUC: {a:.4f}\")"
